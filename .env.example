# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# DRY_RUN=true simulates all on-chain calls (safe, no funds touched).
# Set to false ONLY after a funded wallet + RPC are configured and validated.
DRY_RUN=true

# ── Robinhood Chain (EVM) ────────────────────────────────────────────────────
# Defaults target Robinhood Chain mainnet (chain id 4663).
RPC_URL=https://rpc.mainnet.chain.robinhood.com
CHAIN_ID=4663
# Blockscout instance (REST API, no key needed) — preflight + holder snapshots.
EXPLORER_API=https://robinhoodchain.blockscout.com

# Signing wallet: 0x-prefixed hex private key. MUST be the wallet that DEPLOYED
# PONZI on pons.family — the creator fee share is paid to (and collectFees is
# authorized for) the deployer. In DRY_RUN leave blank — an ephemeral wallet
# is generated.
WALLET_PRIVATE_KEY=

# ── pons.family contracts (Robinhood Chain defaults — override per chain) ─────
PONS_FACTORY=0xA5aAb3F0c6EeadF30Ef1D3Eb997108E976351feB
PONS_LOCKER=0x736D76699C26D0d966744cAe304C000d471f7F35
WETH_ADDRESS=0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73
SWAP_ROUTER=0xCaf681a66D020601342297493863E78C959E5cb2
# Protocol's % cut of each collectFees() payout; the creator gets the remainder.
# pons.family splits trading fees 70% creator / 30% protocol (estimate only — the
# live claim reads the real share on-chain and measures the exact payout).
PROTOCOL_FEE_SHARE_PCT=30

# ── Tokens ───────────────────────────────────────────────────────────────────
# TOKEN_ADDRESS is YOUR PONZI token launched on pons.family. Its creator fees
# fund the cycle.
TOKEN_ADDRESS=
TOKEN_SYMBOL=PONZI

# ── Stock rewards (Uniswap V4) ───────────────────────────────────────────────
# REWARD_BUY_PCT of each claim is split evenly across these stocks, each bought
# with NATIVE ETH on Uniswap V4, then airdropped pro-rata to PONZI holders.
# Blank = the whole verified registry (src/evm/stocks.js):
#   AAPL,AMD,AMZN,GOOGL,META,MSFT,NVDA,SPCX,SPY,TSLA
# Only those have a live native-ETH V4 pool. BE/COIN/CRWV/INTC/MU/ORCL/SNDK/USAR
# exist as tokens but have NO direct ETH pool, so they are not supported.
STOCKS=
# V4 plumbing — the deployments wired to this PoolManager (verified on-chain).
# Stock tokens have no V2 pairs and their V3 pools are empty; V4 holds the real
# liquidity, and an EOA can only swap V4 through the UniversalRouter.
UNIVERSAL_ROUTER=0xC6da9C87caE2fcecad79E22C398dE16BFAb0cFdA
V4_QUOTER=0x628c00B016415Ef530552063faE4154B0CdEb0Ac
POOL_MANAGER=0x8366a39CC670B4001A1121B8F6A443A643e40951

# ── Split (of each WETH claim) ───────────────────────────────────────────────
# REWARD_BUY_PCT → buy STOCKS + airdrop to PONZI holders. The remainder (dev cut)
# stays in the wallet as native ETH for gas.
REWARD_BUY_PCT=80                 # dev cut = 100 - REWARD_BUY_PCT
SLIPPAGE_PCT=5                    # V4 stock-buy slippage tolerance, percent
DEAD_ADDRESS=0x000000000000000000000000000000000000dEaD

# ── Token-side fee: burn + disclosed dev-fee sell ────────────────────────────
# Each cycle, the token-side creator fee (RIF the wallet holds) is split:
#   BURN_PCT %      → burned (sent to DEAD_ADDRESS)
#   the remainder   → sold to ETH on the V3 launch pool by the SELLER wallet, and
#                     the ETH is sent to DEV_WALLET. This is a DISCLOSED dev fee —
#                     the seller wallet is documented publicly (README + /v1) and
#                     is NEVER reported as a "burn".
BURN_PCT=5
# The disclosed fee-conversion wallet (0x-prefixed hex private key). Receives the
# sell-side RIF, sells it, forwards ETH to DEV_WALLET. Must be pre-funded with a
# little native ETH for gas. Required when DRY_RUN=false and BURN_PCT < 100.
SELLER_PRIVATE_KEY=
# ETH destination for the sale proceeds. Blank → the operating wallet.
DEV_WALLET=
SELL_SLIPPAGE_PCT=5               # RIF->WETH slippage tolerance, percent
SELLER_GAS_RESERVE_ETH=0.002      # ETH left in the seller wallet each cycle for gas

# ── Airdrop (stocks → PONZI holders) ─────────────────────────────────────────
MIN_HOLD=100000                    # min PONZI balance to qualify for the airdrop
REWARD_CAP_PCT=0                   # per-wallet weight cap, % of supply (0 = pure pro-rata)
CLUSTERS=[]                        # JSON array of address-groups treated as one wallet
AIRDROP_EXCLUDE=                   # extra excluded owners (pool/treasury), comma-separated
# DISPERSE_ADDRESS: a batch-transfer contract — the big speedup for large holder
# counts. Blank → one transfer per (holder, stock), which is O(holders) txs and
# slow. Set → each stock pays AIRDROP_BATCH_SIZE holders per transaction (~100x
# fewer txs). Verified Disperse contracts on Robinhood Chain:
#   0xDDB6A9b9E2D6C5636B444C0cDA907c9944c6cEC7  (disperseToken)
# The stock tokens are auto-approved to it on first use (one approval per token).
DISPERSE_ADDRESS=0xDDB6A9b9E2D6C5636B444C0cDA907c9944c6cEC7
# With DISPERSE set this is RECIPIENTS PER disperse tx (keep it under the block
# gas limit — ~300 is safe; raise if gas allows). With DISPERSE blank it's the
# sliding-window size for pipelined single transfers.
AIRDROP_BATCH_SIZE=300
AIRDROP_GAS_LIMIT=120000          # fixed gas per pipelined transfer (unused in disperse mode)

# ── Trigger ──────────────────────────────────────────────────────────────────
# The scheduler ticks on POLL_SCHEDULE. TRIGGER_MODE decides the gate:
#   interval     → fire on whatever has accrued every tick (default)
#   accumulation → fire only once claimable >= CLAIM_EVERY_ETH
TRIGGER_MODE=interval
POLL_SCHEDULE=*/5 * * * *          # every 5 minutes
CLAIM_EVERY_ETH=0.005              # accumulation mode: fire when claimable >= this (ETH)
# DRY_RUN only: simulated ETH accrued to the vault per tick (so cycles have fees).
DRY_RUN_FEE_PER_POLL=0.01

# ── Market data (optional) ───────────────────────────────────────────────────
DEXSCREENER_CHAIN_ID=robinhood

# ── Storage (MongoDB) ────────────────────────────────────────────────────────
# Local mongod, or a MongoDB Atlas SRV URI (mongodb+srv://user:pass@cluster/...).
MONGODB_URI=
MONGODB_DB=ponsliqui

# ── Frontend / CORS ──────────────────────────────────────────────────────────
# Comma-separated allowlist of browser origins that may call the API.
# Use "*" to allow any origin (not recommended). Non-browser calls always pass.
CORS_ORIGINS=

# Secret protecting POST /api/run|pause|resume. Blank = open (dev only).
# In production set a long random string; send it as header x-api-key: <key>.
API_KEY=
