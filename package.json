{
  "name": "ponsliqui",
  "version": "0.1.0",
  "private": true,
  "description": "pons.family reward bot on Robinhood Chain: recycles PONZI creator fees into buying tokenized stocks on Uniswap V4 and airdropping them to PONZI holders, plus a dev cut (DRY_RUN first).",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test",
    "check": "node scripts/check.js",
    "claim": "node scripts/claim.js",
    "run-once": "node scripts/run-once.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5",
    "express": "^4.21.2",
    "mongodb": "^6.12.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "mongodb-memory-server": "^10.1.4"
  }
}
